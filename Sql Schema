-- ==========================================
-- Database Schema: Hardware Asset Tracking System
-- Description: Complete DDl script including tables, constraints, foreign keys, and indexes.
-- Target DB: PostgreSQL / Standard SQL Compatibility
--
-- NOTE: This schema has no Users/login table, so there are no passwords here
-- to hash. The actual login table for Crispy Tech Lending is Users in
-- Sql_Schema (and created at runtime in server.js) — that's where password
-- hashing has been applied. See Sql_Schema's Users table comment.
-- ==========================================

-- 1. Table: AssetCategories
CREATE TABLE AssetCategories (
    CategoryID INT GENERATED ALWAYS AS IDENTITY,
    CategoryName VARCHAR(100) NOT NULL,
    Description VARCHAR(255),
    CreatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT PK_AssetCategories PRIMARY KEY (CategoryID)
);

-- 2. Table: Employees
CREATE TABLE Employees (
    EmployeeID INT GENERATED ALWAYS AS IDENTITY,
    FirstName VARCHAR(100) NOT NULL,
    LastName VARCHAR(100) NOT NULL,
    Department VARCHAR(100),
    Email VARCHAR(150),
    CreatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UpdatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT PK_Employees PRIMARY KEY (EmployeeID)
);

-- 3. Table: HardwareInventory
CREATE TABLE HardwareInventory (
    AssetID INT GENERATED ALWAYS AS IDENTITY,
    SerialNumber VARCHAR(100) NOT NULL,
    Brand VARCHAR(100) NOT NULL,
    Model VARCHAR(100) NOT NULL,
    PurchaseDate DATE,
    Status VARCHAR(50) NOT NULL DEFAULT 'Active',
    PurchaseCost DECIMAL(12, 2),
    CategoryID INT NOT NULL,
    CreatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UpdatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT PK_HardwareInventory PRIMARY KEY (AssetID),
    CONSTRAINT UK_HardwareInventory_SerialNumber UNIQUE (SerialNumber),
    CONSTRAINT FK_HardwareInventory_AssetCategories FOREIGN KEY (CategoryID) 
        REFERENCES AssetCategories (CategoryID) ON DELETE RESTRICT
);

-- 4. Table: Assignments
CREATE TABLE Assignments (
    AssignmentID INT GENERATED ALWAYS AS IDENTITY,
    AssetID INT NOT NULL,
    EmployeeID INT NOT NULL,
    DateIssued DATE NOT NULL DEFAULT CURRENT_DATE,
    DateReturned DATE,
    Notes VARCHAR(500),
    CreatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UpdatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT PK_Assignments PRIMARY KEY (AssignmentID),
    CONSTRAINT FK_Assignments_HardwareInventory FOREIGN KEY (AssetID) 
        REFERENCES HardwareInventory (AssetID) ON DELETE CASCADE,
    CONSTRAINT FK_Assignments_Employees FOREIGN KEY (EmployeeID) 
        REFERENCES Employees (EmployeeID) ON DELETE RESTRICT
);

-- 5. Table: MaintenanceLogs
CREATE TABLE MaintenanceLogs (
    LogID INT GENERATED ALWAYS AS IDENTITY,
    AssetID INT NOT NULL,
    PerformedByID INT NOT NULL,
    Status VARCHAR(50) NOT NULL,
    Issue VARCHAR(500) NOT NULL,
    RepairDate DATE NOT NULL DEFAULT CURRENT_DATE,
    ResolvedDate DATE,
    Notes VARCHAR(500),
    Cost DECIMAL(12, 2),
    CreatedAt TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT PK_MaintenanceLogs PRIMARY KEY (LogID),
    CONSTRAINT FK_MaintenanceLogs_HardwareInventory FOREIGN KEY (AssetID) 
        REFERENCES HardwareInventory (AssetID) ON DELETE CASCADE,
    CONSTRAINT FK_MaintenanceLogs_Employees FOREIGN KEY (PerformedByID) 
        REFERENCES Employees (EmployeeID) ON DELETE RESTRICT
);

-- ==========================================
-- INDEXES & ADVANCED CONSTRAINTS
-- ==========================================

-- Partial Index to ensure an asset can have only ONE active (unreturned) assignment at a time.
CREATE UNIQUE INDEX one_active_assignment_per_asset
ON Assignments (AssetID)
WHERE DateReturned IS NULL;

-- General Performance Optimization Indexes
CREATE INDEX IX_HardwareInventory_CategoryID ON HardwareInventory(CategoryID);
CREATE INDEX IX_Assignments_AssetID ON Assignments(AssetID);
CREATE INDEX IX_Assignments_EmployeeID ON Assignments(EmployeeID);
CREATE INDEX IX_MaintenanceLogs_AssetID ON MaintenanceLogs(AssetID);
CREATE INDEX IX_MaintenanceLogs_PerformedByID ON MaintenanceLogs(PerformedByID);